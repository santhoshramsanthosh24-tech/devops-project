{
  "name": "devops-cicd-app",
  "version": "1.0.0",
  "description": "Enterprise DevOps CI/CD Application with Docker and Jenkins",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "test": "node --test tests/unit-tests/*.test.js",
    "test:integration": "node --test tests/integration-tests/*.test.js",
